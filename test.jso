class Vec2 {
    constructor(x: Number, y: Number) {
        this.x = x;
        this.y = y;
    }

    "+"(o: Vec2) {
        return new Vec2(this.x + o.x, this.y + o.y);
    }

    "-"(o: Vec2) {
        return new Vec2(this.x - o.x, this.y - o.y);
    }

    "u-"() {
        return new Vec2(-this.x, -this.y);
    }

    "*"(o: Number) {
        return new Vec2(this.x * o, this.y * o);
    }

    "/"(o: Number) {
        return new Vec2(this.x / o, this.y / o);
    }

    "++"() {
        this.x++;
        this.y++;
    }

    ">"(o: Number) {
        return (this.x > o);
    }
    ">="(o: Number) {
        return (this.x >= o);
    }
}

let a = new Vec2(3,3);
let b = 4;

function check(a: Vec2 = 3, {b: Vec2 = 3} = {}, [c: Vec2 = 3] = []) {}